#!/bin/sh
# Pre-commit hook: run formatting, vet, and lint checks.
# Install via: task install-hooks
#
# This hook catches issues that CI will reject, including:
#   - gofmt formatting drift
#   - go vet failures
#   - golangci-lint issues (with errcheck enabled)

set -e

# --- gofmt ---
# Check all Go files for formatting issues, not just staged ones.
# Staged-only checking misses cases where an edit uncovers a pre-existing
# formatting problem in the same file.
echo "pre-commit: checking gofmt..."
fmt_files=$(gofmt -l .)
if [ -n "$fmt_files" ]; then
    echo "pre-commit: gofmt would reformat the following files:"
    echo "$fmt_files"
    echo "Run 'gofmt -w .' to fix."
    exit 1
fi

# --- go vet ---
echo "pre-commit: running go vet..."
go vet ./...

# --- golangci-lint ---
if ! command -v golangci-lint >/dev/null 2>&1; then
    echo "pre-commit: golangci-lint not found. Install with:"
    echo "  go install github.com/golangci/golangci-lint/v2/cmd/golangci-lint@latest"
    exit 1
fi

echo "pre-commit: running golangci-lint..."
golangci-lint run --enable=errcheck --timeout=5m ./...
