{
  "name": "@nimblemarkets/booba",
  "version": "0.6.0",
  "type": "module",
  "description": "Terminal wrapper for BubbleTea programs using ghostty-web",
  "main": "dist/booba.js",
  "module": "dist/booba.js",
  "types": "dist/booba.d.ts",
  "exports": {
    ".": {
      "import": "./dist/booba.js",
      "types": "./dist/booba.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "build:embed": "tsc -p tsconfig.embed.json && sed -i.bak -e \"s|from 'ghostty-web'|from '../ghostty-web/ghostty-web.js'|\" serve/static/booba/booba.js && rm serve/static/booba/booba.js.bak",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/NimbleMarkets/go-booba.git"
  },
  "license": "MIT",
  "devDependencies": {
    "ghostty-web": "file:./third_party/ghostty-web",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
